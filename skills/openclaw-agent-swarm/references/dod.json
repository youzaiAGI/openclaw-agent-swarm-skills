{
  "checks": {
    "allowed_statuses": [
      "pending",
      "success"
    ],
    "require_clean_worktree": true,
    "require_commits_ahead_base": false,
    "ci_commands": [
      "npm run lint",
      "npm test -- --run"
    ]
  },
  "actions": {
    "push_command": "git push -u origin HEAD",
    "pr_command": ""
  }
}
